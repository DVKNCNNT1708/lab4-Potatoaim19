            "body": {
              "mode": "raw",
              "raw": "{\n  \"cameraId\": \"CAM-CONSUMER-TEST\",\n  \"frameUrl\": \"https://campus.local/webhook-test-frame.jpg\",\n  \"timestamp\": \"2026-05-26T09:00:00Z\",\n  \"requestId\": \"REQ-WEBHOOK-TEST\",\n  \"analysisType\": \"PERSON_DETECTION\"\n}",
